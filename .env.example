# Pilgrim — Root Environment Variables (used by docker-compose)
# Copy this file to .env and update values

# Application
PILGRIM_ENVIRONMENT=local
PILGRIM_DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://pilgrim:pilgrim@postgres:5432/pilgrim
POSTGRES_USER=pilgrim
POSTGRES_PASSWORD=pilgrim
POSTGRES_DB=pilgrim

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_SOFT_TIME_LIMIT=300
CELERY_TIME_LIMIT=360

# Scrapling
PILGRIM_SCRAPLING_BROWSER_INSTALL=false

# Sentry (optional)
SENTRY_DSN=
