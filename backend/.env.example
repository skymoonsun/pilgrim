# Pilgrim Backend — Environment Variables
# Copy this file to .env and update values for your environment

# Application
PILGRIM_ENVIRONMENT=local
PILGRIM_DEBUG=true
LOG_LEVEL=INFO

# Database (async driver required)
DATABASE_URL=postgresql+asyncpg://pilgrim:pilgrim@postgres:5432/pilgrim

# Redis
REDIS_URL=redis://redis:6379/0

# Celery (defaults to REDIS_URL if empty)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_SOFT_TIME_LIMIT=300
CELERY_TIME_LIMIT=360

# Scrapling
PILGRIM_SCRAPLING_BROWSER_INSTALL=false

# SMTP (email notifications)
PILGRIM_SMTP_HOST=localhost
PILGRIM_SMTP_PORT=587
PILGRIM_SMTP_USERNAME=
PILGRIM_SMTP_PASSWORD=
PILGRIM_SMTP_USE_TLS=true
PILGRIM_SMTP_FROM_ADDRESS=pilgrim@localhost

# Sentry (optional)
SENTRY_DSN=

# AI / LLM (optional — set PILGRIM_AI_ENABLED=true to activate)
PILGRIM_AI_ENABLED=false
PILGRIM_LLM_PROVIDER=ollama
PILGRIM_OLLAMA_BASE_URL=http://host.docker.internal:11434
PILGRIM_OLLAMA_MODEL=llama3.2
PILGRIM_OLLAMA_TOKEN=
PILGRIM_AI_MAX_HTML_CHARS=40000
PILGRIM_AI_MAX_VERIFICATION_ITERATIONS=2
